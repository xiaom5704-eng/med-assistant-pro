# LLM Configuration
# Use one of the following:
# 1. BUILT_IN_FORGE_API_KEY - Manus Forge API key (recommended)
# 2. OPENAI_API_KEY - OpenAI API key (fallback)
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom Forge API URL (defaults to https://forge.manus.im/v1/chat/completions)
# BUILT_IN_FORGE_API_URL=https://your-custom-forge-url.com

# Node Environment
NODE_ENV=production
